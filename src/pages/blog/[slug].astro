---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { formatDate } from '../../utils/format';
import 'katex/dist/katex.min.css';

export async function getStaticPaths() {
  const blogEntries = await getCollection('posts');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();
const lang = entry.slug.endsWith('-zh') ? 'zh' : 'en';
const toc = headings.filter(h => h.depth === 2 || h.depth === 3);
const showToc = toc.length >= 3;

// prev/next within published posts of the same language track
const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .filter(p => p.slug.endsWith('-zh') === entry.slug.endsWith('-zh'))
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
const currentIdx = allPosts.findIndex(p => p.slug === entry.slug);
const prevPost = currentIdx > 0 ? allPosts[currentIdx - 1] : null;
const nextPost = currentIdx >= 0 && currentIdx < allPosts.length - 1 ? allPosts[currentIdx + 1] : null;

const postSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: entry.data.title,
  description: entry.data.abstract,
  datePublished: entry.data.date.toISOString(),
  author: {
    '@type': 'Person',
    name: entry.data.author,
    url: 'https://xiangjinyu.github.io',
  },
  image: `https://xiangjinyu.github.io/images/og/${entry.slug}.png`,
  keywords: entry.data.tags.join(', '),
  mainEntityOfPage: `https://xiangjinyu.github.io/blog/${entry.slug}/`,
};
---

<Layout title={entry.data.title} description={entry.data.abstract} lang={lang} ogImage={`/images/og/${entry.slug}.png`} schema={postSchema}>
    <div class="container article-container">
        <header class="article-header">
            <div class="meta">
                <span class="meta-date">{formatDate(entry.data.date)}</span>
                <div class="tags">
                    {entry.data.tags.map(tag => <span class="tag">{tag}</span>)}
                </div>
            </div>
            <h1 transition:name={`post-title-${entry.slug}`}>{entry.data.title}</h1>
            <p class="abstract">{entry.data.abstract}</p>
        </header>

        <article class="content">
            <Content />
        </article>

        {showToc && (
            <aside class="toc" aria-label="Table of contents">
                <span class="toc-label">Contents</span>
                <nav>
                    <ul>
                        {toc.map(h => (
                            <li class={`depth-${h.depth}`}>
                                <a href={`#${h.slug}`}>{h.text}</a>
                            </li>
                        ))}
                    </ul>
                </nav>
            </aside>
        )}

        <nav class="post-nav mono-font" aria-label="Post navigation">
            <div class="post-nav-row">
                {prevPost ? (
                    <a class="post-nav-item prev" href={`/blog/${prevPost.slug}`}>
                        <span class="post-nav-dir">← previous</span>
                        <span class="post-nav-title">{prevPost.data.title}</span>
                    </a>
                ) : <span />}
                {nextPost ? (
                    <a class="post-nav-item next" href={`/blog/${nextPost.slug}`}>
                        <span class="post-nav-dir">next →</span>
                        <span class="post-nav-title">{nextPost.data.title}</span>
                    </a>
                ) : <span />}
            </div>
            <div class="back-links">
                <a href="/blog">← all posts</a>
                <span class="sep">·</span>
                <a href="/">home</a>
            </div>
        </nav>
    </div>
</Layout>

<style>
    .article-container {
        margin-top: 4rem;
        margin-bottom: 4rem;
        max-width: 780px;
    }

    .article-header {
        margin-bottom: 3.5rem;
        border-bottom: 1px solid var(--rule-hairline);
        padding-bottom: 2rem;
    }

    .meta {
        display: flex;
        gap: 1rem;
        align-items: center;
        margin-bottom: 1.2rem;
    }

    .tags {
        display: flex;
        gap: 0.5rem;
    }

    h1 {
        font-size: 2.5rem;
        line-height: 1.15;
        margin-bottom: 1.2rem;
    }

    .abstract {
        font-family: var(--font-serif);
        font-size: 1.2rem;
        color: var(--text-secondary);
        line-height: 1.6;
        font-style: italic;
        max-width: var(--measure);
    }

    /* Article body: serif for reading, sized up for Newsreader's small x-height */
    .content {
        font-family: var(--font-serif);
        font-optical-sizing: auto;
    }

    /* Chinese posts: Newsreader has no CJK glyphs; a serif fallback mix looks
       worse than clean sans, so keep Inter and a calmer size */
    :global(html[lang='zh']) .content {
        font-family: var(--font-sans);
    }

    :global(html[lang='zh']) .content :global(p),
    :global(html[lang='zh']) .content :global(ul),
    :global(html[lang='zh']) .content :global(ol) {
        font-size: 1.05rem;
        line-height: 1.85;
    }

    :global(html[lang='zh']) .content > :global(p:first-of-type)::first-letter {
        font-size: inherit;
        float: none;
        padding: 0;
        margin: 0;
    }

    .content :global(h2) {
        font-family: var(--font-serif);
        font-size: 1.8rem;
        margin-top: 3rem;
        margin-bottom: 1rem;
    }

    .content :global(h3) {
        font-family: var(--font-serif);
        font-size: 1.4rem;
        margin-top: 2rem;
        margin-bottom: 0.8rem;
    }

    .content :global(p) {
        margin-bottom: 1.5rem;
        font-size: 1.18rem;
        line-height: 1.75;
    }

    /* Drop cap on the opening paragraph only */
    .content > :global(p:first-of-type)::first-letter {
        font-size: 3.1em;
        font-weight: 500;
        float: left;
        line-height: 0.82;
        padding-right: 0.09em;
        margin-top: 0.04em;
    }

    .content :global(a) {
        color: var(--accent-color);
    }

    .content :global(a:hover) {
        color: var(--text-primary);
    }

    .content :global(ul), .content :global(ol) {
        margin-bottom: 1.5rem;
        padding-left: 1.5rem;
        font-size: 1.18rem;
        line-height: 1.75;
    }

    .content :global(li) {
        margin-bottom: 0.5rem;
    }

    .content :global(blockquote) {
        border-left: 2px solid var(--accent-color);
        padding-left: 1.2rem;
        margin: 2rem 0;
        color: var(--text-secondary);
        font-style: italic;
    }

    .content :global(code) {
        font-family: var(--font-mono);
        font-size: 0.88em;
        background: var(--bg-tint);
        padding: 0.1em 0.35em;
        border-radius: 3px;
    }

    .content :global(pre) {
        margin: 2rem 0;
        padding: 1.2rem;
        border-radius: 6px;
        overflow-x: auto;
        font-size: 0.88rem;
        line-height: 1.6;
    }

    .content :global(pre code) {
        background: none;
        padding: 0;
    }

    /* Three-line academic table */
    .content :global(table) {
        width: 100%;
        max-width: 100%;
        border-collapse: collapse;
        margin: 2.5rem 0;
        font-size: 0.9rem;
        font-family: var(--font-sans);
    }

    .content :global(th), .content :global(td) {
        text-align: left;
        padding: 0.8rem 1rem 0.8rem 0.5rem;
    }

    .content :global(th) {
        border-top: 2px solid var(--rule-strong);
        border-bottom: 1px solid var(--rule-strong);
        font-weight: 600;
        font-family: var(--font-mono);
        font-size: 0.82rem;
    }

    .content :global(td) {
        color: var(--text-primary);
        border-bottom: 1px solid var(--rule-hairline);
    }

    .content :global(tr:last-child td) {
        border-bottom: 2px solid var(--rule-strong);
    }

    .content :global(.katex-display) {
        overflow-x: auto;
        overflow-y: hidden;
        padding: 1rem 0;
        margin: 1rem 0;
    }

    /* Post navigation */
    .post-nav {
        margin-top: 4.5rem;
        padding-top: 1.6rem;
        border-top: 1px solid var(--rule-hairline);
        font-size: 0.85rem;
    }

    .post-nav-row {
        display: flex;
        justify-content: space-between;
        gap: 2rem;
        margin-bottom: 1.8rem;
    }

    .post-nav-item {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        max-width: 46%;
    }

    .post-nav-item.next {
        text-align: right;
        margin-left: auto;
    }

    .post-nav-dir {
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-tertiary);
    }

    .post-nav-title {
        color: var(--text-secondary);
        line-height: 1.5;
    }

    .post-nav-item:hover .post-nav-title,
    .post-nav-item:hover .post-nav-dir {
        color: var(--accent-color);
    }

    .back-links {
        display: flex;
        gap: 0.8rem;
        font-size: 0.8rem;
    }

    .back-links a {
        color: var(--text-tertiary);
    }

    .back-links a:hover {
        color: var(--accent-color);
    }

    .back-links .sep {
        color: var(--rule-hairline);
    }

    /* TOC: fixed sidebar on wide screens, hidden below 1280px */
    .toc {
        position: fixed;
        top: 140px;
        left: calc(50% + 390px + 3rem);
        width: 220px;
        max-height: calc(100vh - 200px);
        overflow-y: auto;
        font-size: 0.82rem;
    }

    .toc-label {
        font-family: var(--font-mono);
        text-transform: uppercase;
        font-size: 0.68rem;
        letter-spacing: 0.12em;
        color: var(--text-tertiary);
        display: block;
        margin-bottom: 0.8rem;
    }

    .toc ul {
        list-style: none;
        padding: 0;
        margin: 0;
        border-left: 1px solid var(--rule-hairline);
    }

    .toc li {
        margin: 0;
    }

    .toc a {
        display: block;
        padding: 0.28rem 0 0.28rem 0.9rem;
        color: var(--text-tertiary);
        line-height: 1.45;
        border-left: 1px solid transparent;
        margin-left: -1px;
    }

    .toc a:hover {
        color: var(--accent-color);
        border-left-color: var(--accent-color);
    }

    .toc .depth-3 a {
        padding-left: 1.8rem;
        font-size: 0.78rem;
    }

    @media (max-width: 1280px) {
        .toc { display: none; }
    }

    .content :global(h2), .content :global(h3) {
        scroll-margin-top: 100px;
    }

    @media (max-width: 768px) {
        h1 {
            font-size: 2rem;
        }
    }
</style>
