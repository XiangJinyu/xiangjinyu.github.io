---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../utils/format';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Blog - Jinyu Xiang">
    <div class="container blog-page">
        <header class="page-header">
            <span class="section-label">Writing</span>
            <h1>Blog</h1>
            <p>Thoughts on AI Agents, Self-Evolution, and Foundation Models.</p>
        </header>

        <ul class="spine-list post-list">
            {sortedPosts.map(post => (
                <li>
                    <span class="meta-date">{formatDate(post.data.date)}</span>
                    <div class="entry">
                        <h3 transition:name={`post-title-${post.slug}`}><a href={`/blog/${post.slug}`}>{post.data.title}</a></h3>
                        <p class="item-abstract">{post.data.abstract}</p>
                        <div class="item-tags">
                            {post.data.tags.map(tag => (
                                <span class="tag">{tag}</span>
                            ))}
                        </div>
                    </div>
                </li>
            ))}
        </ul>
    </div>
</Layout>

<style>
    .blog-page {
        margin-top: 4rem;
        margin-bottom: 4rem;
    }

    .page-header {
        margin-bottom: 3.5rem;
        border-bottom: 1px solid var(--rule-hairline);
        padding-bottom: 1.8rem;
    }

    .page-header h1 {
        font-size: 3rem;
        margin-bottom: 0.6rem;
    }

    .page-header p {
        font-size: 1.1rem;
        color: var(--text-secondary);
    }

    .post-list > li {
        padding: 0;
        margin-bottom: 3rem;
    }

    .entry h3 {
        font-size: 1.55rem;
        margin-bottom: 0.6rem;
        font-weight: 600;
        line-height: 1.3;
    }

    .entry h3 a {
        color: var(--text-primary);
    }

    .entry h3 a:hover {
        color: var(--accent-color);
    }

    .item-abstract {
        color: var(--text-secondary);
        font-size: 1rem;
        max-width: var(--measure);
        margin-bottom: 1rem;
        line-height: 1.65;
    }

    .item-tags {
        display: flex;
        gap: 0.6rem;
        flex-wrap: wrap;
    }

    @media (max-width: 768px) {
        .page-header h1 {
            font-size: 2.4rem;
        }
    }
</style>
