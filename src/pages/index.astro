---
import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';
import { marked } from 'marked';
import { formatDate } from '../utils/format';
import { Content as AboutContent } from '../about.md';
import { Image } from 'astro:assets';
import SectionIndex from '../components/SectionIndex.astro';
import DailyArtwork from '../components/DailyArtwork.astro';
import ArtReveal from '../components/ArtReveal.astro';
import avatarImg from '../assets/images/avatar.jpg';
import aflowImg from '../assets/images/aflow.png';
import spoImg from '../assets/images/spo.png';
import openmanusImg from '../assets/images/openmanus.png';
import foundationImg from '../assets/images/foundationagent-survey.png';

const pubImages: Record<string, ImageMetadata> = {
  '/images/aflow.png': aflowImg,
  '/images/spo.png': spoImg,
  '/images/openmanus.png': openmanusImg,
  '/images/foundationagent-survey.png': foundationImg,
};

marked.setOptions({ breaks: true, gfm: true });

function parseMarkdown(text: string): string {
  return marked.parseInline(text) as string;
}

function enDash(period: string): string {
  return period.replace(/\s*-\s*/, '–').replace('Present', 'present');
}

const homepageData = await getEntry('data', 'homepage');

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sortedPosts = allPosts
  .filter(p => !p.slug.endsWith('-zh'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const publications = await getCollection('publications');
const sortedPublications = publications.sort((a, b) => a.data.order - b.data.order);
const featuredPubs = sortedPublications.filter(p => p.data.image);
const otherPubs = sortedPublications.filter(p => !p.data.image);

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Jinyu Xiang',
  alternateName: ['Xiang Jinyu', '向劲宇'],
  url: 'https://xiangjinyu.github.io',
  image: 'https://xiangjinyu.github.io/images/avatar.jpg',
  jobTitle: 'Algorithm Researcher',
  worksFor: { '@type': 'Organization', name: 'Xiaomi Mimo-Core' },
  email: 'mailto:xiangjy2001@gmail.com',
  sameAs: [
    'https://github.com/XiangJinyu',
    'https://twitter.com/CosmoJinyu',
    'https://scholar.google.com/citations?user=NJv62qoAAAAJ',
  ],
  knowsAbout: ['AI Agents', 'Agent Self-Evolution', 'Foundation Models', 'Large Language Models'],
};
---

<Layout title="Jinyu Xiang · AI Agent Researcher" schema={personSchema}>
    <ArtReveal />
    <SectionIndex />
    <!-- About -->
    <section class="hero" id="about-me">
        <div class="about-header">
            <div class="avatar rise" style="--stagger: 1">
                <Image src={avatarImg} alt="Jinyu Xiang" width={320} height={320} format="webp" quality={85} />
            </div>
            <div class="intro">
                <h1 class="rise" style="--stagger: 0">Jinyu Xiang</h1>
                <p class="tagline rise" style="--stagger: 2">Algorithm Researcher at Xiaomi Mimo-Core · AI Agent Researcher · Musician</p>
                <div class="social-links rise" style="--stagger: 3">
                    <a href="mailto:xiangjy2001@gmail.com" title="Email">Email</a>
                    <a href="https://github.com/XiangJinyu" title="GitHub">GitHub</a>
                    <a href="https://twitter.com/CosmoJinyu" title="Twitter">Twitter</a>
                    <a href="https://scholar.google.com/citations?user=NJv62qoAAAAJ&hl=en" title="Google Scholar">Scholar</a>
                </div>
            </div>
        </div>
        <div class="about-content rise" style="--stagger: 4">
            <AboutContent />
        </div>
    </section>

    <!-- News -->
    <section class="section reveal" id="news">
        <header class="section-head">
            <span class="section-label">01 — News</span>
            <h2>News</h2>
        </header>
        <ul class="spine-list">
            {homepageData?.data.news?.map(item => (
                <li>
                    <span class="meta-date">{item.date}</span>
                    <span class="entry" set:html={parseMarkdown(item.content)} />
                </li>
            ))}
        </ul>
    </section>

    <!-- Publications -->
    <section class="section reveal" id="publications">
        <header class="section-head">
            <span class="section-label">02 — Research</span>
            <h2>Selected Publications</h2>
        </header>

        {featuredPubs.map(async (pub) => {
            const { Content } = await pub.render();
            const localImage = pub.data.image ? pubImages[pub.data.image] : undefined;
            return (
                <div class="publication">
                    <div class="pub-side">
                        <a href={pub.data.url} class="pub-image">
                            {localImage
                                ? <Image src={localImage} alt={pub.data.title} width={560} format="webp" quality={82} />
                                : <img src={pub.data.image} alt={pub.data.title} loading="lazy" />}
                        </a>
                        <span class="meta-date">{pub.data.badge.toUpperCase()}</span>
                    </div>
                    <div class="pub-content">
                        <h3><a href={pub.data.url}>{pub.data.title}</a></h3>
                        <p class="authors" set:html={parseMarkdown(pub.data.authors)} />
                        <div class="description">
                            <Content />
                        </div>
                    </div>
                </div>
            );
        })}

        <ul class="spine-list compact-pubs">
            {otherPubs.map(pub => (
                <li>
                    <span class="meta-date">{pub.data.badge.toUpperCase()}</span>
                    <div class="entry">
                        <h3 class="compact-title"><a href={pub.data.url}>{pub.data.title}</a></h3>
                        <p class="compact-authors" set:html={parseMarkdown(pub.data.authors)} />
                    </div>
                </li>
            ))}
        </ul>
    </section>

    <!-- Experience -->
    <section class="section reveal" id="internships">
        <header class="section-head">
            <span class="section-label">03 — Experience</span>
            <h2>Job Experience</h2>
        </header>
        <ul class="spine-list">
            {homepageData?.data.jobs?.map(item => (
                <li>
                    <span class="meta-date">{enDash(item.period)}</span>
                    <span class="entry">
                        {item.title}, {item.url ? <a href={item.url}>{item.company}</a> : item.company}, China.
                    </span>
                </li>
            ))}
        </ul>
    </section>

    <!-- Projects -->
    <section class="section reveal" id="competitions">
        <header class="section-head">
            <span class="section-label">04 — Projects</span>
            <h2>Competitions and Side Projects</h2>
        </header>
        <ul class="spine-list">
            {homepageData?.data.projects?.map(item => (
                <li>
                    <span class="meta-date">{item.date}</span>
                    <span class="entry">
                        <a href={item.url}>{item.title}</a>, <span set:html={parseMarkdown(item.description)} />
                    </span>
                </li>
            ))}
        </ul>
    </section>

    <!-- Talks -->
    <section class="section reveal" id="invited-talks">
        <header class="section-head">
            <span class="section-label">05 — Talks</span>
            <h2>Invited Talks</h2>
        </header>
        <ul class="spine-list">
            {homepageData?.data.talks?.map(item => (
                <li>
                    <span class="meta-date">{item.date}</span>
                    <span class="entry"><a href={item.url} class="quiet-link">{item.title}</a></span>
                </li>
            ))}
        </ul>
    </section>

    <!-- Blog -->
    <section class="section reveal" id="blog">
        <header class="section-head">
            <span class="section-label">06 — Writing</span>
            <h2>Recent Blog Posts</h2>
        </header>
        <ul class="spine-list blog-list">
            {sortedPosts.slice(0, 5).map(post => (
                <li>
                    <span class="meta-date">{formatDate(post.data.date)}</span>
                    <div class="entry">
                        <h3 class="post-title" transition:name={`post-title-${post.slug}`}><a href={`/blog/${post.slug}`}>{post.data.title}</a></h3>
                        <p class="abstract">{post.data.abstract}</p>
                        <div class="tags">
                            {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
                        </div>
                    </div>
                </li>
            ))}
        </ul>
        <div class="view-all">
            <a href="/blog">View all posts →</a>
        </div>
    </section>

    <DailyArtwork id="gallery" label="07 — Gallery · Today's painting" heading="Daily Artwork" />
</Layout>

<style>
    /* Hero */
    .hero {
        position: relative;
        max-width: var(--container-width);
        margin: 3.5rem auto 5rem;
        padding: 0 1.5rem;
        scroll-margin-top: 90px;
    }

    .about-header {
        position: relative;
        display: grid;
        grid-template-columns: var(--spine-width) 1fr;
        gap: var(--spine-gap);
        align-items: center;
        margin-bottom: 2.5rem;
    }

    .avatar :global(img) {
        width: 100%;
        max-width: 150px;
        height: auto;
        aspect-ratio: 1;
        border-radius: 50%;
        object-fit: cover;
        box-shadow: 0 1px 4px rgba(26, 22, 12, 0.12);
        display: block;
    }

    .intro h1 {
        font-size: 2.6rem;
        line-height: 1.15;
        margin-bottom: 0.4rem;
    }

    .tagline {
        font-size: 1.05rem;
        color: var(--text-secondary);
        margin-bottom: 1.1rem;
    }

    .social-links {
        display: flex;
        gap: 0.8rem;
        flex-wrap: wrap;
    }

    .social-links a {
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--text-secondary);
        padding: 0.28rem 0.6rem;
        border: 1px solid var(--rule-hairline);
        border-radius: 4px;
        transition: all 0.2s;
    }

    .social-links a:hover {
        color: var(--accent-color);
        border-color: var(--accent-color);
    }

    .about-content {
        padding-left: calc(var(--spine-width) + var(--spine-gap));
    }

    .about-content :global(p) {
        font-size: 1.08rem;
        max-width: var(--measure);
        color: var(--text-primary);
        margin-bottom: 1.4rem;
        line-height: 1.8;
    }

    .about-content :global(a) {
        color: var(--accent-color);
    }

    .about-content :global(a:hover) {
        color: var(--text-primary);
    }

    /* Sections */
    .section {
        max-width: var(--container-width);
        margin: 0 auto 5.5rem;
        padding: 0 1.5rem;
        scroll-margin-top: 90px;
    }

    .section-head {
        margin-bottom: 2.2rem;
        padding-bottom: 0.9rem;
        border-bottom: 1px solid var(--rule-hairline);
    }

    .section-head h2 {
        font-size: 1.9rem;
        font-weight: 600;
    }

    /* Publications — featured rows on the spine grid, image in the spine column */
    .publication {
        display: grid;
        grid-template-columns: var(--spine-width) 1fr;
        gap: var(--spine-gap);
        margin-bottom: 2.4rem;
        padding-bottom: 2.4rem;
        border-bottom: 1px solid var(--rule-hairline);
    }

    .pub-side {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }

    .pub-image {
        display: block;
    }

    .pub-image :global(img) {
        width: 100%;
        height: auto;
        aspect-ratio: 4 / 3;
        object-fit: contain;
        background: var(--bg-card);
        border: 1px solid var(--rule-hairline);
        border-radius: 4px;
        display: block;
        transition: border-color 0.2s;
    }

    .pub-image:hover :global(img) {
        border-color: var(--accent-color);
    }

    .pub-content h3 {
        font-size: 1.45rem;
        line-height: 1.3;
        margin-bottom: 0.7rem;
        font-weight: 600;
    }

    .pub-content h3 a {
        color: var(--text-primary);
    }

    .pub-content h3 a:hover {
        color: var(--accent-color);
    }

    .authors {
        font-size: 0.92rem;
        color: var(--text-secondary);
        margin-bottom: 0.8rem;
        font-style: italic;
        max-width: var(--measure);
    }

    .authors :global(strong) {
        font-weight: 600;
        font-style: normal;
        color: var(--text-primary);
    }

    .description :global(p) {
        font-size: 0.98rem;
        color: var(--text-secondary);
        line-height: 1.7;
        max-width: var(--measure);
        margin: 0;
    }

    /* Publications — compact list */
    .compact-pubs {
        margin-top: 0.4rem;
    }

    .compact-pubs > li {
        margin-bottom: 1.8rem;
    }

    .compact-title {
        font-size: 1.15rem;
        line-height: 1.35;
        font-weight: 600;
        margin-bottom: 0.3rem;
    }

    .compact-title a {
        color: var(--text-primary);
    }

    .compact-title a:hover {
        color: var(--accent-color);
    }

    .compact-authors {
        font-size: 0.85rem;
        color: var(--text-tertiary);
        font-style: italic;
        line-height: 1.55;
    }

    .compact-authors :global(strong) {
        font-weight: 600;
        font-style: normal;
        color: var(--text-secondary);
    }

    /* Blog list */
    .blog-list > li {
        margin-bottom: 2.4rem;
    }

    .post-title {
        font-size: 1.35rem;
        margin-bottom: 0.4rem;
        font-weight: 600;
    }

    .post-title a {
        color: var(--text-primary);
    }

    .post-title a:hover {
        color: var(--accent-color);
    }

    .abstract {
        color: var(--text-secondary);
        font-size: 0.95rem;
        margin-bottom: 0.8rem;
        line-height: 1.65;
        max-width: var(--measure);
    }

    .tags {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .view-all {
        margin-top: 2.2rem;
        padding-left: calc(var(--spine-width) + var(--spine-gap));
    }

    .view-all a {
        font-family: var(--font-mono);
        font-size: 0.85rem;
        color: var(--accent-color);
    }

    .view-all a:hover {
        color: var(--text-primary);
    }

    @media (max-width: 768px) {
        .about-header {
            grid-template-columns: 1fr;
            text-align: center;
            gap: 1.5rem;
        }

        .avatar :global(img) {
            margin: 0 auto;
            max-width: 120px;
        }

        .about-content {
            padding-left: 0;
        }

        .intro h1 {
            font-size: 2rem;
        }

        .social-links {
            justify-content: center;
        }

        .publication {
            grid-template-columns: 1fr;
            gap: 1rem;
        }

        .pub-side {
            flex-direction: row;
            align-items: flex-end;
        }

        .pub-image {
            max-width: 220px;
        }

        .view-all {
            padding-left: 0;
        }
    }
</style>
