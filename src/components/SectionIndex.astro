---
// Fixed left-margin section index with scrollspy.
// Mirrors the numbered section labels; visible only on wide viewports.
const sections = [
    { id: 'about-me', num: '00', label: 'About' },
    { id: 'news', num: '01', label: 'News' },
    { id: 'publications', num: '02', label: 'Research' },
    { id: 'internships', num: '03', label: 'Experience' },
    { id: 'competitions', num: '04', label: 'Projects' },
    { id: 'invited-talks', num: '05', label: 'Talks' },
    { id: 'blog', num: '06', label: 'Writing' },
];
---
<nav class="section-index" aria-label="Section index">
    <ul>
        {sections.map(s => (
            <li>
                <a href={`/#${s.id}`} data-section={s.id}>
                    <span class="idx-num">{s.num}</span>
                    <span class="idx-label">{s.label}</span>
                </a>
            </li>
        ))}
    </ul>
</nav>

<style>
    .section-index {
        position: fixed;
        top: 50%;
        transform: translateY(-50%);
        left: calc(50% - var(--container-width) / 2 - 7.5rem);
        z-index: 50;
    }

    /* Hide when the margin can't fit it */
    @media (max-width: 1360px) {
        .section-index { display: none; }
    }

    ul {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    a {
        display: flex;
        align-items: baseline;
        gap: 0.55rem;
        padding: 0.28rem 0.5rem;
        font-family: var(--font-mono);
        font-size: 0.68rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-tertiary);
        border-left: 1px solid var(--rule-hairline);
        transition: color 0.2s, border-color 0.2s;
    }

    .idx-num {
        font-size: 0.62rem;
        opacity: 0.7;
    }

    .idx-label {
        opacity: 0;
        transform: translateX(-4px);
        transition: opacity 0.25s, transform 0.25s;
    }

    .section-index:hover .idx-label {
        opacity: 1;
        transform: translateX(0);
    }

    a:hover {
        color: var(--text-primary);
    }

    a.active {
        color: var(--accent-color);
        border-left-color: var(--accent-color);
    }

    a.active .idx-label {
        opacity: 1;
        transform: translateX(0);
    }
</style>

<script>
    function initSectionIndex() {
        const nav = document.querySelector('.section-index');
        if (!nav || (nav as HTMLElement).dataset.bound) return;
        (nav as HTMLElement).dataset.bound = '1';

        const links = new Map<string, Element>();
        nav.querySelectorAll('a[data-section]').forEach(a => {
            links.set((a as HTMLElement).dataset.section!, a);
        });

        const targets = [...links.keys()]
            .map(id => document.getElementById(id))
            .filter((el): el is HTMLElement => !!el);
        if (!targets.length) return;

        let current: Element | null = null;
        function setActive(id: string) {
            const link = links.get(id);
            if (!link || link === current) return;
            current?.classList.remove('active');
            link.classList.add('active');
            current = link;
        }

        const io = new IntersectionObserver((entries) => {
            // pick the entry closest to the top band of the viewport
            const visible = entries.filter(e => e.isIntersecting);
            if (visible.length) {
                visible.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
                setActive(visible[0].target.id);
            }
        }, { rootMargin: '-15% 0px -70% 0px' });

        targets.forEach(t => io.observe(t));
        setActive(targets[0].id);
    }
    initSectionIndex();
    document.addEventListener('astro:page-load', initSectionIndex);
</script>
