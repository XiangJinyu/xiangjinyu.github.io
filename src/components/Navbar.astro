---
// Site navigation
---
<header transition:persist="navbar">
    <nav class="nav-container">
        <a href="/" class="logo">
            <span class="dot"></span> Jinyu Xiang
        </a>
        <div class="nav-links">
            <a href="/#about-me">About</a>
            <a href="/#news">News</a>
            <a href="/#publications">Publications</a>
            <a href="/blog">Blog</a>
            <button id="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
                <svg class="icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
                <svg class="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            </button>
        </div>
    </nav>
</header>

<script>
    function initThemeToggle() {
        const btn = document.getElementById('theme-toggle');
        if (!btn || btn.dataset.bound) return;
        btn.dataset.bound = '1';
        btn.addEventListener('click', (e) => {
            const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
            const apply = () => {
                document.documentElement.dataset.theme = next;
                localStorage.setItem('theme', next);
            };

            const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            if (!document.startViewTransition || reduce) { apply(); return; }

            const rect = btn.getBoundingClientRect();
            const x = rect.left + rect.width / 2;
            const y = rect.top + rect.height / 2;
            const r = Math.hypot(Math.max(x, innerWidth - x), Math.max(y, innerHeight - y));

            document.documentElement.classList.add('theme-inking');
            const t = document.startViewTransition(apply);
            t.ready.then(() => {
                document.documentElement.animate(
                    { clipPath: [`circle(0px at ${x}px ${y}px)`, `circle(${r}px at ${x}px ${y}px)`] },
                    { duration: 550, easing: 'cubic-bezier(0.4, 0, 0.2, 1)', pseudoElement: '::view-transition-new(root)' }
                );
            });
            t.finished.finally(() => document.documentElement.classList.remove('theme-inking'));
        });
    }
    initThemeToggle();
    document.addEventListener('astro:after-swap', initThemeToggle);
</script>

<style>
    header {
        padding: 1.6rem 0;
        position: sticky;
        top: 0;
        background: var(--nav-bg);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        z-index: 100;
        border-bottom: 1px solid var(--rule-hairline);
        /* isolate on its own compositor layer: prevents repaint flicker
           from backdrop-filter + sticky on WebKit/Blink */
        transform: translateZ(0);
    }

    .nav-container {
        max-width: var(--container-width);
        margin: 0 auto;
        padding: 0 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
    }

    .logo {
        font-family: var(--font-serif);
        font-size: 1.45rem;
        font-weight: 600;
        color: var(--text-primary);
        display: flex;
        align-items: center;
        gap: 0.6rem;
        white-space: nowrap;
    }

    .dot {
        display: inline-block;
        width: 9px;
        height: 9px;
        background-color: var(--accent-color);
        border-radius: 50%;
    }

    .logo:hover .dot {
        animation: dot-hop 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @keyframes dot-hop {
        0%   { transform: translateY(0); }
        40%  { transform: translateY(-5px); }
        100% { transform: translateY(0); }
    }

    @media (prefers-reduced-motion: reduce) {
        .dot { animation: none !important; }
    }

    @keyframes dot-breathe {
        0%, 100% { transform: scale(1); opacity: 1; }
        50%      { transform: scale(0.82); opacity: 0.75; }
    }

    .logo:hover .dot {
        animation: dot-hop 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @keyframes dot-hop {
        0%   { transform: translateY(0); }
        40%  { transform: translateY(-5px); }
        100% { transform: translateY(0); }
    }

    @media (prefers-reduced-motion: reduce) {
        .dot { animation: none; }
    }

    .nav-links {
        display: flex;
        gap: 2.2rem;
        align-items: center;
    }

    .nav-links a {
        font-size: 0.9rem;
        color: var(--text-secondary);
        font-weight: 500;
    }

    .nav-links a:hover {
        color: var(--text-primary);
    }

    #theme-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: none;
        border: 1px solid var(--rule-hairline);
        border-radius: 4px;
        width: 28px;
        height: 28px;
        color: var(--text-secondary);
        cursor: pointer;
        transition: color 0.2s, border-color 0.2s;
    }

    #theme-toggle:hover {
        color: var(--accent-color);
        border-color: var(--accent-color);
    }

    .icon-moon { display: block; }
    .icon-sun { display: none; }

    :global([data-theme='dark']) .icon-moon { display: none; }
    :global([data-theme='dark']) .icon-sun { display: block; }

    @media (max-width: 768px) {
        header {
            padding: 1rem 0;
        }

        .nav-container {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.5rem;
        }

        .logo {
            font-size: 1.3rem;
        }

        .nav-links {
            gap: 1.4rem;
            overflow-x: auto;
            max-width: 100%;
        }

        .nav-links a {
            font-size: 0.85rem;
            white-space: nowrap;
        }
    }
</style>
