---
// A quiet curation: one artwork from Google Arts & Culture.
// Data: the public JSON used by Google's official "Art Tab" extension.
// mode="daily"  → same painting for everyone on a given date
// mode="random" → a new painting every load (used on /404)
interface Props {
    mode?: 'daily' | 'random';
    label?: string;
    heading?: string;
    id?: string;
}
const { mode = 'daily', label = "Today's painting", heading, id } = Astro.props;
---
<section class:list={['artwork', { 'has-heading': !!heading }]} data-mode={mode} id={id} hidden>
    {heading ? (
        <header class="section-head">
            <span class="section-label">{label}</span>
            <h2>{heading}</h2>
        </header>
    ) : (
        <span class="section-label">{label}</span>
    )}
    <div class="artwork-body">
        <div class="artwork-meta mono-font">
            <p class="artwork-title"></p>
            <p class="artwork-creator"></p>
            <p class="artwork-attribution"></p>
            <a class="artwork-link" target="_blank" rel="noopener">view on Google<br />Arts &amp; Culture →</a>
        </div>
        <a class="artwork-frame" target="_blank" rel="noopener">
            <img alt="" decoding="async" />
        </a>
    </div>
</section>

<style>
    .artwork {
        max-width: var(--container-width);
        margin: 0 auto 5.5rem;
        padding: 0 1.5rem;
        scroll-margin-top: 90px;
    }

    .section-head {
        margin-bottom: 2.2rem;
        padding-bottom: 0.9rem;
        border-bottom: 1px solid var(--rule-hairline);
    }

    .section-head h2 {
        font-size: 1.9rem;
        font-weight: 600;
    }

    .artwork-body {
        display: grid;
        grid-template-columns: var(--spine-width) 1fr;
        gap: var(--spine-gap);
        align-items: start;
    }

    /* Metadata lives in the spine column, like every other section */
    .artwork-meta {
        font-size: 0.78rem;
        line-height: 1.7;
        color: var(--text-tertiary);
        padding-top: 0.3rem;
    }

    .artwork-title {
        color: var(--text-secondary);
        font-style: italic;
    }

    .artwork-creator {
        color: var(--text-secondary);
        margin-top: 0.3rem;
    }

    .artwork-attribution {
        margin-top: 0.3rem;
    }

    .artwork-link {
        display: inline-block;
        margin-top: 1rem;
        color: var(--text-tertiary);
    }

    .artwork-link:hover {
        color: var(--accent-color);
    }

    /* The painting is the content: generous, but bounded */
    .artwork-frame {
        display: block;
        justify-self: start;
        background: var(--bg-card);
        border: 1px solid var(--rule-hairline);
        padding: 10px;
        transition: border-color 0.2s;
    }

    .artwork-frame:hover {
        border-color: var(--accent-color);
    }

    .artwork-frame img {
        display: block;
        max-width: 100%;
        max-height: 340px;
        width: auto;
        height: auto;
        filter: saturate(0.92);
        opacity: 0;
        transition: opacity 0.45s ease;
    }

    .artwork-frame img.is-loaded {
        opacity: 1;
    }

    :global([data-theme='dark']) .artwork-frame img {
        filter: saturate(0.88) brightness(0.9);
    }

    @media (max-width: 768px) {
        .artwork-body {
            grid-template-columns: 1fr;
            gap: 1rem;
        }

        /* On mobile, painting first, caption below — like a plate in a book */
        .artwork-frame { order: -1; }

        .artwork-frame img {
            max-height: 300px;
        }

        .artwork-link br { display: none; }
    }
</style>

<script>
    const JSON_URL = 'https://www.gstatic.com/culturalinstitute/tabext/imax_2_2.json';
    const GAC_BASE = 'https://artsandculture.google.com/';

    interface Artwork {
        title: string;
        creator: string;
        attribution: string;
        image: string;
        link: string;
    }

    async function loadArtworks(): Promise<Artwork[]> {
        const cached = sessionStorage.getItem('gac-artworks');
        if (cached) return JSON.parse(cached);
        const res = await fetch(JSON_URL);
        if (!res.ok) throw new Error(String(res.status));
        const data = await res.json();
        try { sessionStorage.setItem('gac-artworks', JSON.stringify(data)); } catch { /* quota: skip */ }
        return data;
    }

    function dailyIndex(len: number): number {
        const d = new Date();
        const seed = d.getFullYear() * 10000 + (d.getMonth() + 1) * 100 + d.getDate();
        // xorshift-ish scramble so consecutive days don't pick neighbours
        let x = seed ^ 0x9e3779b9;
        x ^= x << 13; x ^= x >> 17; x ^= x << 5;
        return Math.abs(x) % len;
    }

    async function initArtwork() {
        const sections = document.querySelectorAll<HTMLElement>('.artwork:not([data-bound])');
        if (!sections.length) return;

        let artworks: Artwork[];
        try {
            artworks = await loadArtworks();
        } catch {
            return; // degrade silently: section stays hidden
        }
        if (!artworks?.length) return;

        sections.forEach(section => {
            section.dataset.bound = '1';
            const idx = section.dataset.mode === 'random'
                ? Math.floor(Math.random() * artworks.length)
                : dailyIndex(artworks.length);
            const art = artworks[idx];

            const img = section.querySelector('img')!;
            const frame = section.querySelector<HTMLAnchorElement>('.artwork-frame')!;
            const link = section.querySelector<HTMLAnchorElement>('.artwork-link')!;
            const href = GAC_BASE + art.link;

            img.src = `${art.image}=s1200-rw`;
            img.alt = `${art.title} — ${art.creator}`;
            frame.href = href;
            link.href = href;
            section.querySelector('.artwork-title')!.textContent = `“${art.title}”`;
            section.querySelector('.artwork-creator')!.textContent = art.creator;
            section.querySelector('.artwork-attribution')!.textContent = art.attribution?.trim() ?? '';

            img.addEventListener('load', () => {
                section.hidden = false;
                requestAnimationFrame(() => img.classList.add('is-loaded'));
            }, { once: true });
            // One retry at a smaller size (helps transient 429s), then give up quietly
            let retried = false;
            img.addEventListener('error', () => {
                if (!retried) {
                    retried = true;
                    setTimeout(() => { img.src = `${art.image}=s640-rw`; }, 1500);
                } else {
                    section.remove();
                }
            });
        });
    }

    initArtwork();
    document.addEventListener('astro:page-load', initArtwork);
</script>
